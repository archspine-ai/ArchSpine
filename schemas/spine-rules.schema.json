{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://archspine.dev/schema/v1.0.0/spine-rules.schema.json",
  "title": "ArchSpine SpineRuleDocument",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "ruleId",
    "title",
    "summary",
    "appliesTo",
    "severity",
    "enforceable",
    "bodyMarkdown"
  ],
  "properties": {
    "schemaVersion": {
      "$ref": "./shared.schema.json#/$defs/schemaVersion"
    },
    "ruleId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "$ref": "./shared.schema.json#/$defs/nonEmptyString"
    },
    "summary": {
      "$ref": "./shared.schema.json#/$defs/nonEmptyString"
    },
    "appliesTo": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./shared.schema.json#/$defs/nonEmptyString"
      }
    },
    "severity": {
      "type": "string",
      "enum": ["advisory", "warning", "error"]
    },
    "enforceable": {
      "type": "boolean"
    },
    "rationale": {
      "type": ["string", "null"]
    },
    "bodyMarkdown": {
      "$ref": "./shared.schema.json#/$defs/nonEmptyString"
    }
  }
}
