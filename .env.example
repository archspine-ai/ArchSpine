# ==========================================
# ArchSpine Environment Variables
# ==========================================
# Prefer `spine llm setup` for normal usage. 
# Use these env vars for CI or one-off runtime overrides. 
# Note: Project config (.spine/config.json) wins over env values.

# --- Core LLM Configuration ---
# Provider: openai, deepseek, openrouter, gemini
# SPINE_PROVIDER=deepseek

# API Key for the selected provider
# SPINE_API_KEY=your_api_key_here

# Optional: Custom model (e.g., deepseek-chat, gpt-4o, gemini-1.5-flash)
# SPINE_MODEL=deepseek-chat

# Optional: Custom Base URL (required for OpenRouter or compatible services)
# SPINE_BASE_URL=https://openrouter.ai/api/v1

# --- Runtime Tuning ---
# Recommended runtime mode: standard or heavy
# Leave unset to let project config decide.
# SPINE_MODE=heavy

# Optional advanced prompt override: lite, balanced, or exhaustive
# Use `lite` only if `mode=standard` is still too heavy for your model's context window.
# SPINE_PROMPT_TIER=lite

# --- Local LLMs (Ollama / LM Studio) ---
# SPINE_PROVIDER=openai
# SPINE_API_KEY=ollama
# SPINE_MODEL=qwen2.5:14b
# Default Ollama port:
# SPINE_BASE_URL=http://localhost:11434/v1
# Default LM Studio port:
# SPINE_BASE_URL=http://localhost:1234/v1

# --- Features ---
# Enable pre-commit hook bypass or enforcement
# SPINE_PRECOMMIT=true
