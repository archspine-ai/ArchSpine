# =============================================================================
# ArchSpine — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in values as needed. All variables are
# optional — ArchSpine works out of the box with sensible defaults.
# =============================================================================

# --- LLM Provider Configuration ---
# Configured via `spine llm setup` and stored in the OS keychain/credential
# manager. Environment variables take precedence for CI/CD or headless use.

# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...

# --- Diagnostics ---
# Set to "on" to emit detailed relevance diagnostics during LLM summarization.
# SPINE_DIAGNOSTICS_MODE=on

# --- Runtime Behavior ---
# ArchSpine manages its own secret storage via OS keychain backends. These
# env vars are used internally by the credential scripts and should NOT be
# set manually:
#   ARCHSPINE_SECRET_NAME
#   ARCHSPINE_SECRET_ACCOUNT
#   ARCHSPINE_KEYCHAIN_SECRET
