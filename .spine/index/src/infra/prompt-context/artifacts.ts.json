  "semantic": {
    "role": "Orchestrator for building compacted source prompt artifacts used in LLM prompts, integrating policy resolution, budget calculation, trimming, and diagnostics from sub-modules.",
    "responsibilities": [
      "Accepts SourcePromptArtifactsInput and returns a fully constructed SourcePromptArtifacts object.",
      "Resolves the validation policy via resolveValidatePolicy based on task mode and input policy.",
      "Calculates source prompt budgets (header lines, dependency context character limit) via calculateSourcePromptBudgets.",
      "Extracts a skeleton representation by taking the first header lines from the source content.",
      "Applies trimming strategies: compactSkeletonForPrompt on the skeleton, trimSectionedContext on dependency context, trimRuleBlocks on rule data, and trimPreviousSemantic on previous semantic analysis.",
      "Builds diagnostics for dependency selection and rule blocks via buildDependencySelectionDiagnostics and buildRuleBlockDiagnostics.",
      "Serializes artifacts to JSON strings for inclusion in prompt context."
    ],
