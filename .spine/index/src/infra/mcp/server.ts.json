  "semantic": {
    "role": "MCP (Model Context Protocol) server bootstrap that initializes the MCP server instance, registers all request handlers for tools, resources, and prompts, and connects to stdio transport. Serves as the primary entry point for external MCP clients (e.g., IDEs, AI agents) to interact with ArchSpine capabilities.",
    "responsibilities": [
      "Initialize and configure the MCP server using the SDK Server class with capabilities for resources, tools, and prompts.",
      "Register request handlers for ListResources, ReadResource, ListTools, CallTool, ListPrompts, and GetPrompt requests.",
      "Delegate tool execution and resource retrieval to the SpineTools and SpineResources modules respectively.",
      "Enforce the MCPContextGate authentication/authorization layer for access control.",
      "Map internal errors to standard MCP error responses using toArchSpineError.",
      "Connect the server to StdioServerTransport for standard I/O communication.",
      "Provide error logging and graceful initialization failure handling."
    ],
    "outOfScope": [
      "Implementation of individual tools (handled by SpineTools).",
      "Implementation of individual resource providers (SpineResources).",
      "Configuration loading and validation (Config facade).",
      "Manifest loading and management (Manifest facade).",
      "Context gate logic details (MCPContextGate)."
    ],
    "invariants": [
      "All request handlers are registered before the server connects to the transport.",
      "Server lifecycle is fully managed within this class (init -> connect).",
      "Context gate is consistently applied to tool and resource access."
    ],
