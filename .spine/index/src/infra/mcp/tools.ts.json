      },
      {
        "symbolName": "previewScan",
        "description": "Executes a quick scan preview to detect changes without persisting results to the spine index."
      },
      {
        "symbolName": "getDriftHistory",
        "description": "Retrieves historical drift records for a given symbol or module path."
      },
      {
        "symbolName": "getFileContext",
        "description": "Returns contextual information about a specific file, including its AST and symbol definitions."
      },
      {
        "symbolName": "getViewData",
