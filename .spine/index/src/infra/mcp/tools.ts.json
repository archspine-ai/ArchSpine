      },
      {
        "symbolName": "queryGraph",
        "description": "Queries the dependency graph using operations such as upstream, downstream, walk, and violation edges."
      },
      {
        "symbolName": "getDiagnostics",
        "description": "Returns diagnostic information from the dependency graph, including cycles, dead code, and hub modules."
      },
      {
        "symbolName": "matchSemanticTool",
