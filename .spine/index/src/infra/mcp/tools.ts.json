  "semantic": {
    "role": "MCP (Model Context Protocol) tool facade that wraps core ArchSpine system components (Scanner, RuleEngine, Manifest, Config) into a unified interface for external AI agents.",
    "responsibilities": [
      "Exposes ArchSpine system capabilities as MCP tools: queryInvariants, queryResponsibilities, previewScan, getDriftHistory, getFileContext, getViewData, getViolationsSummary, listResourceTemplates.",
      "Provides baseline status (getBaselineStatus) and sync status (getSyncStatus) by interfacing with the Manifest and file system.",
      "Performs preview scanning by loading rules from a directory, instantiating the Scanner and RuleEngine, and filtering matched invariants/responsibilities for a given file path.",
      "Retrieves drift history from the index document and offers file context and view data for system introspection.",
      "Notes tool calls on the MCPContextGate for audit/tracing.",
      "Validates index document compatibility before reading drift history."
    ],
    "outOfScope": [
      "Direct execution of scans or rule evaluations outside the MCP tool interface.",
      "Scheduling, persistence, or daemon management of the ArchSpine system.",
      "User authentication and session management.",
      "Handling of raw file system operations not related to .spine directory."
    ],
    "invariants": [
      "Infra modules must expose stable low-level capabilities and facades; they must not absorb service/task/engine orchestration concerns (but this facade necessarily absorbs some orchestration to function)."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a stable, queryable MCP tool interface that exposes ArchSpine’s architectural governance capabilities (invariants, responsibilities, scanning, drift) to external AI agents, without exposing internal engine APIs directly.",
      "recentChangeIntent": "ArchSpine v1.0.0 — Architectural Governance & Semantic Layer for the AI Era (general intial release intent, consistent with tool interface introduction)."
    },
    "publicSurface": [
      "SpineTools class constructor",
