  "semantic": {
    "role": "Concrete LLM provider implementation for Google's Gemini API, handling structured summary generation for ArchSpine's mirror system.",
    "responsibilities": [
      "Implements the LLMClient interface to generate semantic summaries for config, document, source, folder, and project file kinds.",
      "Formats prompts using the ArchSpine prompt engine (generateConfigPrompt, generateDocumentPrompt, etc.) tailored to each FileKind.",
      "Executes requests to the Gemini API via GoogleGenerativeAI with configurable model and generation strategy.",
      "Parses structured responses from Gemini (JSON blocks and markdown) using utility functions like parseStructuredResponse and parseMarkdownBlocks.",
      "Aggregates usage information across multiple API calls for a single summary generation."
    ],
    "outOfScope": [
      "Does not implement provider for other LLM APIs (e.g., OpenAI, Anthropic).",
      "Does not define prompt templates; delegates to the prompt engine in ../../prompt.js.",
      "Does not handle caching or persistence of generated summaries.",
      "Does not manage API keys or provider configuration beyond initial setup."
    ],
    "invariants": [
      "Must remain a thin LLM interaction layer without absorbing orchestration logic from services or tasks.",
      "Must not directly access the file system or repository structure."
    ],
