  "semantic": {
    "role": "OpenAI-compatible LLM provider client with embedded prompt generation and response parsing orchestration, contrary to the Infra Facade design rule.",
    "responsibilities": [
      "Initializes the OpenAI SDK client with configurable API endpoint, model, API key, and timeout from ProviderConfig.",
      "Implements the LLMClient interface to generate semantic summaries for each FileKind (source, document, config, folder, project, markdown).",
      "Uses imported prompt generators (generateSourcePrompt, generateConfigPrompt, etc.) to create structured prompts for each file type.",
      "Calls the OpenAI chat completions API with constructed prompts and parses the response into structured JSON and markdown blocks via utility functions.",
      "Merges token usage information across sequential calls for aggregated reporting.",
      "Builds supporting context (e.g., previous semantics) using the imported buildSupportingContext utility."
    ],
    "outOfScope": [
      "Prompt generation and strategy orchestration should be handled by a dedicated orchestration layer, not by a low-level LLM provider client.",
      "Response parsing into domain-specific structures should be performed by an orchestrator, not by the transport-level client.",
      "FileKind-specific content preparation (e.g., mapping file types to prompts) belongs outside the provider."
    ],
    "invariants": [
      "LLM provider clients must not import prompt generation or response parsing utilities that belong in a higher-level orchestration layer.",
      "LLM provider clients should expose a single generate(prompt) method and remain transport-focused facades.",
      "Public infra facades should be preferred over direct imports from deep private implementation paths."
    ],
    "changeIntent": {
      "architecturalIntent": "Establish a clean layered architecture where LLM providers are thin transport facades, and prompt generation/response parsing is extracted into a shared orchestration layer.",
      "recentChangeIntent": "ArchSpine v1.0.0 — Architectural Governance & Semantic Layer for the AI Era; the current provider violates this intent by containing embedded orchestration logic."
    },
    "publicSurface": [
      "class OpenAICompatibleClient implements LLMClient"
    ],
    "ruleViolations": [
      {
        "id": "infra-facade-imports",
        "severity": "warning",
        "reason": "The OpenAICompatibleClient imports prompt generation functions and response parsing utilities, absorbing orchestration concerns that should reside in a dedicated orchestration layer. This violates the rule that infra modules must not absorb service/task/engine orchestration concerns."
