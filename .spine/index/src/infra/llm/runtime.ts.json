  "semantic": {
    "role": "Infrastructure module for LLM runtime configuration resolution and provider client factory, strictly limited to merging configuration sources and instantiating LLM clients.",
    "responsibilities": [
      "Resolves LLM settings (provider, model, base URL, API key) by merging project configuration, global configuration, environment variables, and runtime overrides with defined precedence.",
      "Parses and validates LLM mode, prompt policy tier, and validate policy from resolved configuration using dedicated parsers.",
      "Creates LLM provider client instances via LLMFactory based on fully resolved settings.",
      "Provides a helper to check whether a given provider requires an API key.",
      "Asserts that resolved LLM settings are usable for a given command context, raising ArchSpineError if required settings are missing."
    ],
    "outOfScope": [
      "Runtime orchestration (e.g., prompt execution flow, caching, fallback chains) – explicitly delegated to services/runtime-service.ts.",
      "Direct interaction with LLM provider APIs beyond client instantiation.",
      "User-facing prompt composition or response handling."
    ],
    "invariants": [
      "Infra module must not absorb service/task/engine orchestration concerns; this module adheres by limiting to config resolution and client creation.",
      "Callers should prefer public infra facades over deep private implementation paths; exports here form the intended public surface.",
      "Configuration precedence must be maintained: overrides > environment > global config > project config."
    ],
    "changeIntent": {
      "architecturalIntent": "Establish a clean infrastructure layer for LLM configuration resolution and client instantiation, ensuring that runtime orchestration remains in the services layer.",
      "recentChangeIntent": "v1.0.0 architectural governance: formalizing the separation between infra (resolution, client creation) and services (orchestration)."
