  "semantic": {
    "role": "Runtime database facade / data access aggregator providing a unified interface over file tracking, symbol indexing, usage logging, violation recording, drift history, and batch operations for the ArchSpine governance engine.",
    "responsibilities": [
      "Aggregate and expose all runtime database operations through a single SpineDB class, hiding the internal repository module structure.",
      "Manage the lifecycle of the better-sqlite3 database connection, including initialization and schema setup.",
      "Provide file-level tracking operations: ensuring file records, updating status, retrieving docs, deleting records, and listing tracked files.",
      "Provide symbol-level operations: adding/clearing file exports, resolving symbols by name, searching across the symbol index, and cache invalidation.",
      "Provide usage logging operations: recording usage entries, retrieving total usage, and summarizing usage data.",
      "Provide violation management operations: recording violations, clearing violations, deleting orphan violations, and retrieving active violations.",
      "Provide drift history retrieval for governance analysis.",
      "Support batch commits for atomic multi-operation updates."
    ],
    "outOfScope": [
      "Direct execution of raw SQL queries; those are delegated to repository modules.",
      "Schema migration logic beyond initialization; schema changes are handled by the schema module.",
      "Connection pooling or multi-instance concurrency; assumes single-process better-sqlite3 usage.",
      "CLI/UI interface; this is a pure data-access layer."
    ],
    "invariants": [
      "SpineDB must remain the single public entry point for runtime database operations; all callers must use SpineDB rather than importing repository modules directly to preserve stable import surfaces (per rule infra-facade-imports).",
      "All public methods on SpineDB should delegate to repository functions, never bypassing them."
    ],
    "changeIntent": {
      "architecturalIntent": "Introduce a unified facade (SpineDB) that aggregates all runtime database repositories, providing a single class for consumers to interact with the governance engine's persistent state.",
      "recentChangeIntent": "Added violation lifecycle management methods (recordViolation, clearViolations, deleteOrphanViolations, getActiveViolations) to support the --fresh check flag and violation lifecycle feature."
    },
    "publicSurface": [
