  "semantic": {
    "role": "Facade class that orchestrates file tracking, metadata management, and persistence operations over the SpineDB.",
    "responsibilities": [
      "Create, update, and delete file records in the SpineDB via `ensureTracked`, `commitBatch`, and `deleteFile`.",
      "Retrieve file documents and tracked file lists via `getFileDocs` and `getTrackedFiles`.",
      "Query drift history for a specific file via `getDriftHistory`.",
      "Coordinate state persistence and baseline detection by delegating to the manifest state module (load/save manifest state, check needsInitialSync, persist reverse index state)."
    ],
    "outOfScope": [
      "Low-level SpineDB operations (direct database queries).",
      "File system I/O (scanning, reading files).",
      "Configuration management, CLI, MCP tools, or HTTP services.",
      "Language-specific parsing or aggregation logic."
    ],
    "invariants": [
      "Manifest is the sole public entry point for manifest operations; consumers must not directly import from io, state, or integrity modules within this package (enforced by infra-facade-imports rule).",
      "All file operations must go through the SpineDB instance owned by Manifest; no direct state mutations outside this class.",
      "In-memory state (e.g., reverseIndexComplete) must be persisted via delegated state methods before a new session expects to use it."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a stable, encapsulated API for the manifest subsystem, hiding database layout and internal persistence logic from higher-level services.",
      "recentChangeIntent": "No significant semantic change detected from git intent; minor adjustments for consistency."
    },
    "publicSurface": [
      {
        "symbolName": "Manifest",
        "description": "Public class that exposes the stable API for all manifest file tracking operations. Consumed by services like sync-service, check-service, and fix-service."
      },
      {
        "symbolName": "Manifest.constructor(db, rootDir)",
        "description": "Initializes a new Manifest instance with the provided SpineDB and project root directory. Called once at system startup."
      },
      {
        "symbolName": "Manifest.ensureTracked(filePath, language, content?)",
        "description": "Creates or updates a file record in the database, computing the content hash and committing the change. Called when a file is first discovered or modified."
      },
      {
        "symbolName": "Manifest.commitBatch(commits)",
        "description": "Atomically persists a batch of file status updates, recording the commit history for each file. Called by sync-service to apply a set of changes."
      },
      {
        "symbolName": "Manifest.getFileDocs(filePath)",
        "description": "Retrieves all document records associated with a given file path. Called by view services to render file details."
      },
      {
        "symbolName": "Manifest.getTrackedFiles()",
        "description": "Returns the complete list of tracked file records from the database. Used for enumeration and summary generation."
      },
      {
        "symbolName": "Manifest.getDriftHistory(filePath)",
        "description": "Queries the drift event history for a specific file, returning an array of DriftEvent objects. Used by drift detection and risk assessment."
      },
      {
        "symbolName": "Manifest.deleteFile(filePath)",
        "description": "Deletes a file record and its associated documents from the database. Called when a file is removed from the project."
      }
    ],
