  "semantic": {
    "role": "Centralized file I/O module for synchronizing and removing ArchSpine-managed configuration blocks in repository files (gitignore, gitattributes, agent instructions, search ignore, spine ignore, package.json scripts).",
    "responsibilities": [
      "Defines and exports status type unions (e.g., GitIgnoreSyncStatus, PackageScriptRemovalStatus) for tracking outcomes of sync/removal operations.",
      "Normalizes agent instructions filename to 'AGENTS.md' when trimmed input is empty.",
      "Returns the appropriate set of managed .gitignore lines based on ArtifactStrategy (local vs distributable).",
      "Inserts, updates, and removes bounded blocks (delimited by START/END markers) in .gitignore files.",
      "Inserts, updates, and removes bounded blocks in .gitattributes files.",
      "Creates or updates the agent instructions file (AGENTS.md) with ArchSpine agent instruction blocks.",
      "Synchronizes search ignore file with ArchSpine-managed content.",
      "Synchronizes spine ignore file with ArchSpine-managed content.",
      "Injects or removes ArchSpine npm scripts (e.g., 'spine:check') in package.json.",
      "Removes managed blocks from .gitignore, .gitattributes, agent instructions, search ignore, spine ignore, and package.json, with optional deletion of the host file."
    ],
    "outOfScope": [
      "Content validation or semantic checking of the managed blocks after synchronization.",
      "Any version control operations (git add, commit, push).",
      "Parsing or interpreting the contents of the injected scripts beyond the block delimiters."
    ],
    "invariants": [
      "Sync functions are idempotent: running them multiple times yields the same state as a single run.",
      "Removal functions only remove content between recognized ArchSpine block delimiters; non-managed content outside the block is preserved.",
      "Normalizing a filename that is empty or whitespace-only defaults to 'AGENTS.md'."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a single, consistent utility layer for lifecycle management (sync and removal) of all ArchSpine-specific configuration sections across multiple repository file types, ensuring idempotent operations and minimal disruption to existing files.",
      "recentChangeIntent": "As part of the ArchSpine v1.0.0 release, this module was expanded to cover agent instructions file synchronization and package.json script injection/removal, completing the initial set of managed configuration artifacts."
    },
