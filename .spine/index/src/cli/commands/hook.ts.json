  "semantic": {
    "role": "CLI command adapter for managing git hook installation, configuration, and execution within the ArchSpine system.",
    "responsibilities": [
      "Parses the hook synchronization mode from string input to enforce valid configuration.",
      "Enables the pre-commit git hook by installing the hook script and setting the configuration flag to true.",
      "Disables the pre-commit git hook by uninstalling the hook script and resetting the configuration flag.",
      "Reports the current hook status, including enabled/disabled state and synchronization mode, to the user.",
      "Triggers the synchronization workflow by delegating to the runSyncWorkflow function when the 'run' action is invoked."
    ],
    "outOfScope": [
      "Direct git operations beyond hook script management.",
      "Implementation of the synchronization pipeline or persistence of git state."
    ],
