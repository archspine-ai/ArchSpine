      "Simplified Chinese": {
        "role": "CLI 命令适配器，用于编排 ArchSpine 镜像系统的完整同步工作流，包括参数解析、脊线门控强制、修复策略评估以及执行检查点管理。",
        "responsibilities": [
          "解析并验证同步命令的 CLI 参数（full、hookMode、repairViolations、retryFailed），并显示 UI 横幅。",
          "通过协调调用 Scanner、Manifest、RuntimeService 以及语言发现模块（discoverLanguages、diffLanguages）来编排同步工作流。",
          "在执行同步前调用 detectProtectedOutputMutations 强制脊线门控保护。",
          "当检测到受保护输出发生变更时，通过 evaluateRepairPolicy 评估并应用修复策略。",
          "使用 withProtectedOutputsWriteAccess 保护受保护输出的写入操作，确保安全变更。",
          "通过 ExecutionCheckpointStore 管理执行检查点，以检测并恢复部分同步失败的情况。",
          "通过 deriveSyncFailedCandidateFiles 从执行检查点数据中派生用于重试的候选文件。",
          "将错误转换为 ArchSpineError，确保 CLI 层错误报告的一致性。"
        ],
        "outOfScope": [
          "实现文件系统遍历或索引的扫描器逻辑。",
          "包含运行时 LLM 推理或提示语生成逻辑。",
          "包含语言发现算法或差异计算。",
          "管理配置文件或清单状态的持久化。"
        ]
      }
    }
