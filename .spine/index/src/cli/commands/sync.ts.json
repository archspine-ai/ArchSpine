  "semantic": {
    "role": "CLI command adapter that orchestrates the complete synchronization workflow for the ArchSpine mirror system, including argument parsing, spine gate enforcement, repair policy evaluation, and execution checkpoint management.",
    "responsibilities": [
      "Parses and validates CLI arguments for the sync command (full, hookMode, repairViolations, retryFailed) and displays the UI banner.",
      "Orchestrates the sync workflow by coordinating calls to Scanner, Manifest, RuntimeService, and language discovery (discoverLanguages, diffLanguages).",
      "Enforces spine gate protection by invoking detectProtectedOutputMutations before executing the sync.",
      "Evaluates and applies repair policies via evaluateRepairPolicy when protected output mutations are detected.",
      "Guards write operations on protected outputs using withProtectedOutputsWriteAccess to ensure safe mutation.",
      "Manages execution checkpoints via ExecutionCheckpointStore to detect and recover from partial sync failures.",
      "Derives candidate files for retry from execution checkpoint data using deriveSyncFailedCandidateFiles.",
      "Converts errors to ArchSpineError for consistent error reporting across the CLI layer."
    ],
    "outOfScope": [
      "Implements scanner logic for file system traversal or indexing.",
      "Contains runtime LLM inference or prompt generation logic.",
      "Contains language discovery algorithms or diff computations.",
      "Manages persistence of configuration files or manifest state."
    ],
    "invariants": [
      "Must delegate heavy pipeline logic to engines and services, adhering to the cli-entrypoint-separation rule.",
      "Must always call withProtectedOutputsWriteAccess before writing to protected outputs.",
      "Must always execute detectProtectedOutputMutations before initiating sync to prevent unauthorized changes.",
      "Must convert all errors to ArchSpineError via toArchSpineError for uniform error handling.",
      "Must manage execution checkpoints to support recovery from interrupted sync operations."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a resilient and governance-aware CLI command for synchronizing the ArchSpine mirror system, integrating spine gate protection, repair policy evaluation, and execution checkpoint management.",
      "recentChangeIntent": "Add execution checkpoint integration and writer boundary protection to enhance failure recovery and enforce output mutation safety."
    },
    "publicSurface": [
      "executeSyncCommand(options)",
      "runSyncWorkflow(options)",
      "ExecuteSyncCommandOptions"
    ],
