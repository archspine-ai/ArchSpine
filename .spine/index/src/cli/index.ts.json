  "semantic": {
    "role": "CLI entrypoint and command dispatcher for the ArchSpine mirror system. Routes top-level commands to dedicated handler modules after setting up global HTTP proxy and environment configuration.",
    "responsibilities": [
      "Configure global HTTP/HTTPS proxy agent from environment variables at startup using the 'undici' library.",
      "Parse CLI arguments and display banners, general help, or command-specific help as appropriate.",
      "Dispatch top-level commands (init, sync, build, llm, remove, check, scan, config, mcp, info, view, try, skill, rules) to their respective execute*Command functions.",
      "Provide usage error messages and early exit for unrecognized commands or missing arguments.",
      "Load configuration via Config, Manifest, Secrets, and LLM configuration to determine if a project or baseline exists, influencing the command flow."
    ],
    "outOfScope": [
      "Business logic or pipeline execution (delegated to services and core modules).",
      "Persistence or data storage operations (handled by infra modules).",
      "LLM provider implementations or orchestration (handled by infra/llm).",
      "File-level source analysis or summary generation (handled by engines and tasks)."
    ],
    "invariants": [
      "Must not absorb pipeline or persistence logic (rule cli-entrypoint-separation).",
      "Must remain a thin command adapter; all substantive work must be delegated to services, core, engines, or infra.",
      "Must be the single entry point for the CLI tool, executable via '#!/usr/bin/env node'."
    ],
    "changeIntent": {
      "architecturalIntent": "Maintain a thin CLI entrypoint that delegates all functional behavior to modular command handlers and service layers, ensuring reusability and testability outside the CLI.",
      "recentChangeIntent": "Recent commit 'd63e898 1' introduced additional modular command imports (scan, view, try, skill, rules, mcp, etc.) to expand CLI capabilities without bloating the entrypoint."
    },
    "publicSurface": [],
    "ruleViolations": [],
    "driftDetected": false,
    "driftReason": null,
    "localized": {
      "English": {
        "role": "Primary CLI entrypoint for ArchSpine. On startup it configures a global HTTP proxy from environment variables, then parses command-line arguments to display help, a dashboard, or route to one of many command modules (init, sync, build, check, scan, config, view, try, skill, rules, mcp, info, llm, remove).",
        "responsibilities": [
          "Set up global HTTP/HTTPS proxy via the 'undici' ProxyAgent if environment variables are present.",
          "Print a banner and route requests to general help, command-specific help, or a dashboard view.",
          "Dispatch recognized commands to execute*Command functions imported from separate command modules.",
          "Exit with a usage error when an unknown command or missing subcommand is encountered.",
          "Load configuration, manifest, secrets, and LLM settings early to conditionally guide CLI behavior."
        ],
        "outOfScope": [
          "Core business logic, LLM orchestration, file analysis, or state persistence — these are delegated to dedicated service and infrastructure modules."
        ]
      }
    }
  },
