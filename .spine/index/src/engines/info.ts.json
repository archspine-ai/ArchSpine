    "publicSurface": [
      {
        "symbolName": "runInfoReport",
        "description": "Generates a structured info report for an ArchSpine project at the given rootDir. Reads the project manifest, configuration, scanner state, and LLM settings, then outputs the report via runtimeIO.info calls. The optional runtimeIO parameter allows callers to supply a custom output adapter."
      }
