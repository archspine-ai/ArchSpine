  "semantic": {
    "role": "Pipeline stage task that orchestrates LLM-based semantic summarization and synthesis from extracted source artifacts, consuming skeletons and units to produce structured semantic output with drift awareness and validation.",
    "responsibilities": [
      "Process extracted artifacts (skeletons, units, violations) by invoking the LLM to generate per-file semantic summaries and structured symbols.",
      "Build prompt artifacts using `buildSourcePromptArtifacts` and resolve validation policies via `resolveValidatePolicy` to guide the LLM generation.",
      "Handle semantic drift detection by comparing the new LLM output against the previous semantic context (`PreviousSemanticContext`), adding drift warnings when the contract changes.",
      "Retry LLM calls on transient failures using `isRetryableError` and `p-limit` concurrency control.",
      "Calculate structural and semantic footprints (`calculateStructuralFootprint`, `calculateSemanticFootprint`) for each processed file.",
      "Manage task state transitions: mark processed files, queue commits, increment success/failure/skipped counters, and record usage and diagnostics.",
      "Produce and return `SummarizationStageOutput` containing the synthesized semantics, updated skeletons, and accumulated violations.",
      "Integrate with the manifest to record violations and trigger index updates when forced sync is requested."
    ],
    "outOfScope": [
      "CLI command parsing or direct user interaction",
      "Unrelated service orchestration (e.g., view rendering, MCP server, database CRUD outside task state)",
      "Source code extraction (handled by preceding ExtractionTask stage)",
      "File system scanning or repository index building",
      "Final artifact output formatting (delegated to writer boundary or output manager)"
    ],
