  "semantic": {
    "role": "ArchSpine summarization stage task module implementing SpineTask interface to orchestrate LLM-based semantic summary generation from extraction stage outputs.",
    "responsibilities": [
      "Implements the SummarizationTask class extending SpineTask to drive the summarization pipeline stage, consuming ExtractionStageOutput and producing SummarizationStageOutput.",
      "Filters and processes selected source files from extraction stage outputs, skipping non-source files via LangRegistry.isSourceFile.",
      "Builds LLM prompt artifacts for each file using buildSourcePromptArtifacts to provide relevant context and previous summaries to the model.",
      "Manages concurrent summarization tasks using pLimit to control parallel LLM requests and respect rate limits.",
      "Tracks task progress, drifts, diagnostics, and failures using task-state utilities (e.g., markTaskProcessedFile, addTaskDriftWarning, pushSummarizeDiagnostics, incrementTaskFailed, queueTaskCommit).",
      "Commit summarized results to the pipeline via queueTaskCommit and manages pending commits for synchronization."
    ],
    "outOfScope": [
      "Direct CLI argument parsing or command routing.",
      "Non-summarization pipeline stages (extraction, indexing, verification).",
      "LLM model specific configuration or provider selection."
    ],
    "invariants": [
      "Must implement SpineTask contract with name, checkpointId, and run method.",
      "Must respect stage boundaries and not take over other stages' responsibilities.",
      "Must use LangRegistry for file type filtering."
    ],
    "changeIntent": {
      "architecturalIntent": "Provides the summarization stage within the ArchSpine pipeline, transforming extracted source code artifacts into semantic summaries via LLM integration, with concurrency management and progress tracking.",
      "recentChangeIntent": "Optimized LLM summarization pipeline to improve concurrency control, reliability, and integration with credential store hardening."
    },
