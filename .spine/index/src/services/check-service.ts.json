  "semantic": {
    "role": "Service facade orchestrating the ArchSpine 'check' command pipeline, coordinating scanning, AST extraction, and validation tasks via a managed runtime session.",
    "responsibilities": [
      "Orchestrates the sequential execution of ScanAndCleanupTask, ASTExtractionTask, and ValidationTask using a TaskRunner within a managed runtime session.",
      "Manages session lifecycle and resumable execution checkpoints via runWithRuntimeSession and deriveCheckResumeCandidateFiles.",
      "Records usage metrics and validation summaries into the project manifest via context.manifest.recordUsage.",
      "Handles errors, logs stage-specific metrics (file counts, byte sizes), and formats byte counts for human-readable output via formatBytes.",
      "Provides a reusable CheckService class and a convenience async runCheck function that accept root directory, optional LLM client, and scan policy."
    ],
    "outOfScope": [
      "Low-level scanner implementation (src/core/scanner.ts)",
      "AST parsing logic (src/tasks/ast-extra.ts)",
      "LLM client initialization and authentication (src/infra/llm.ts)",
      "File system I/O abstractions (src/infra/runtime-io.ts)",
      "Execution checkpoint persistence details (src/infra/execution-checkpoint.ts)"
    ],
    "invariants": [
      "Services may orchestrate core/tasks/infra modules but must not replace infrastructure responsibilities.",
      "View-specific service modules must reside under src/services/view/ (rule service-runtime-boundary)."
    ],
