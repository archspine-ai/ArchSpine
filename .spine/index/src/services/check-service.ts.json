      "architecturalIntent": "Provide a centralized orchestration layer for the 'check' command, enabling consistent scan, validation, and usage recording flow.",
      "recentChangeIntent": "Part of ArchSpine v1.0.0 release that establishes the architectural governance and semantic validation pipeline."
    },
    "publicSurface": [
      "runCheck function: async convenience orchestration",
