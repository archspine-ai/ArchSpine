  "semantic": {
    "role": "Primary orchestration service for the ArchSpine 'check' pipeline — coordinates scanning, AST extraction, validation, and cleanup tasks in a single workflow. Used by CLI commands and programmatic consumers to run governance checks on a repository.",
    "responsibilities": [
      "Expose `runCheck` function for simple CLI/one-shot usage with minimal configuration (rootDir, optional llmClient, optional scanPolicy).",
      "Expose `CheckService` class for programmatic orchestration with full options via `CheckServiceOptions` (rootDir, llmClient, scanPolicy, runtimeIO).",
      "Orchestrate the full check workflow: start a runtime session, resolve scan policy, create task context (with checkpoint for resumability), run ScanAndCleanupTask, ASTExtractionTask, and ValidationTask sequentially via TaskRunner.",
      "Report stage-level metrics (bytes processed, durations) to the runtime IO for observability.",
      "Handle errors by converting them to ArchSpineError via toArchSpineError and log error details."
    ],
    "outOfScope": [
      "Does not perform file scanning, AST extraction, or validation logic directly — delegates to task classes.",
      "Does not parse CLI arguments or handle user input parsing.",
      "Does not manage LLM client lifecycle beyond accepting an optional LLMClient reference.",
      "Does not implement progress bars or interactive UI — outputs structured log messages via RuntimeIO."
    ],
    "invariants": [
      "The check pipeline always runs ScanAndCleanupTask, ASTExtractionTask, and ValidationTask in that order.",
      "Task context is created via createTaskContext, which uses deriveCheckResumeCandidateFiles to enable resumable runs.",
      "Errors are wrapped as ArchSpineError using toArchSpineError before propagation.",
      "The runtime session is managed via runWithRuntimeSession, ensuring proper lifecycle hooks.",
      "This service does not implement view-specific logic; it lives under src/services/ not src/services/view/."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a clean orchestration entry point for the check pipeline that separates concerns: service coordinates, tasks execute, infra provides I/O and checkpointing.",
      "recentChangeIntent": "feat: add violation lifecycle management and --fresh check flag. This is consistent with the orchestration role, adding capability to manage violation lifecycle and support fresh runs, though the specific implementation details are in other files."
    },
    "publicSurface": [
      {
        "symbolName": "runCheck",
        "description": "One-shot check function accepting rootDir, optional LLMClient, and optional ScanPolicy. Creates a default runtime I/O, instantiates CheckService internally, and runs the check pipeline. Used by CLI or scripts that need minimal setup."
      },
      {
        "symbolName": "CheckService",
        "description": "Programmatic orchestration class for the check pipeline. Accepts CheckServiceOptions for full control. Exposes a `run(context?)` method that executes the pipeline tasks in order. Consumed by the CLI command handler and programmatic consumers."
      },
      {
        "symbolName": "CheckServiceOptions",
        "description": "Configuration interface for CheckService. Includes rootDir (required), optional llmClient, optional scanPolicy, and optional runtimeIO for custom logging and file operations."
      }
    ],
