  "semantic": {
    "role": "CLI-level orchestration module for applying and verifying the ArchSpine repository artifact strategy (e.g., agent instruction files, gitignore, scripts, rule templates). It coordinates the initial bootstrap and ongoing sync of managed repository files during 'init', 'sync', and 'scan' CLI commands.",
    "responsibilities": [
      "Detect mismatches between the intended artifact strategy and the current repository state (e.g., which agent instruction file is selected, whether managed blocks are present and complete).",
      "Apply the desired artifact strategy by writing/updating config, gitignore, gitattributes, and agent instruction files.",
      "Install default rule templates (layered-architecture.yml, naming-conventions.yml) into the repository's .spine/rules/ directory.",
      "Synchronize V2 agent instruction blocks (health block, MCP tools block, briefing block, etc.) with the selected agent instruction file (e.g., CLAUDE.md or AGENTS.md).",
      "Synchronize all managed repository files (.gitignore, .gitattributes, .spineignore, .searchignore) with ArchSpine's managed blocks.",
      "Inject npm scripts (e.g., `spine-sync`, `spine-scan`, `spine-check`) into the repository's package.json.",
      "Return typed result structures detailing what was checked or applied."
    ],
    "outOfScope": [
      "Source code scanning or violation detection (handled by scanner engines).",
      "Aggregating atomic units or building index structures.",
      "Generating view data (architecture diagram, public surface, risk hotspots).",
      "LLM interaction, prompt building, or content generation.",
      "Database operations or persistent state management."
    ],
    "invariants": [
      "The artifact strategy (ArtifactStrategy) must be consistent between the config and the actual repository state after application.",
      "All managed blocks must be present and contain exactly the expected markers (e.g., BEGIN/END comments).",
      "The repository must have the required configuration files (package.json, .gitignore, .gitattributes) before strategy application can succeed."
    ],
    "changeIntent": {
      "architecturalIntent": "Consolidate repository initialisation and synchronization logic into a single CLI-level strategy module, decoupling it from infra and utils while providing clear typed results for each operation.",
      "recentChangeIntent": "Refactored to remove legacy CLI aliases; the module now centralises all repository strategy operations for init/sync flows, matching the cleanup described in the recent commit."
    },
    "publicSurface": [
      {
        "symbolName": "checkRepositoryStrategy",
        "description": "Compares the current repository configuration against the intended artifact strategy and returns a list of issues to resolve. Called during `spine init` and `spine sync` preflight checks."
      },
      {
        "symbolName": "applyRepositoryStrategy",
        "description": "Applies the next artifact strategy to the repository, updating config, agent instruction files, and managed blocks accordingly. Called during `spine init` and `spine sync` to enforce the desired setup."
      },
      {
        "symbolName": "installRecommendedRuleTemplates",
        "description": "Copies the default architectural rule templates (layered-architecture.yml, naming-conventions.yml) into the .spine/rules directory of the repository. Used during first-time initialisation."
      },
      {
        "symbolName": "syncV2AgentInstructionBlocks",
        "description": "Synchronises V2 agent instruction blocks (health, MCP tools, briefing, etc.) into the selected agent instruction file. Called by syncAgentInstructionsConfiguration."
      },
      {
        "symbolName": "syncAgentInstructionsConfiguration",
        "description": "Full synchronisation of agent instruction configuration: updates health blocks, MCP tools blocks, V2 blocks, removes stale sections, and reports sync status. Called during `spine sync`."
      },
      {
        "symbolName": "syncManagedRepositoryFiles",
        "description": "Synchronises managed files (gitignore, gitattributes, spineignore, searchignore) with ArchSpine's managed blocks using the given artifact strategy. Called during `spine sync`."
      },
      {
        "symbolName": "injectRepositoryPackageScripts",
        "description": "Adds or updates npm scripts for ArchSpine commands (spine-sync, spine-scan, etc.) in the repository's package.json. Called during `spine init`."
      },
      {
        "symbolName": "RepositoryStrategyCheckResult",
        "description": "Typed result of checkRepositoryStrategy, containing the current strategy, next strategy, and a list of identified issues."
      },
      {
        "symbolName": "RepositoryStrategyApplyResult",
        "description": "Typed result of applyRepositoryStrategy, reporting which strategy was applied and whether files were updated."
      },
      {
        "symbolName": "RuleTemplateInstallResult",
        "description": "Typed result of installRecommendedRuleTemplates, listing whether each template file was created or already existed."
      },
      {
        "symbolName": "AgentInstructionsSyncResult",
        "description": "Typed result of syncAgentInstructionsConfiguration, containing sync statuses for agent instructions, health blocks, MCP tools blocks, and V2 blocks."
      },
      {
        "symbolName": "ManagedRepositoryFilesResult",
        "description": "Typed result of syncManagedRepositoryFiles, reporting sync status for each managed file (gitignore, gitattributes, spineignore, searchignore)."
      },
      {
        "symbolName": "InjectPackageScriptsResult",
        "description": "Typed result of injectRepositoryPackageScripts, detailing which scripts were added or updated."
      },
      {
        "symbolName": "V2BlockSyncResults",
        "description": "Typed collection of V2 block sync statuses, used inside AgentInstructionsSyncResult to describe the outcome of syncV2AgentInstructionBlocks."
      }
