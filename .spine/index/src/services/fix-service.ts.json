      },
      "Simplified Chinese": {
        "role": "ArchSpine 架构修复管道的服务层编排器，负责顺序执行扫描、AST提取、LLM驱动的校正和验证任务，并支持重试机制和运行时会话集成。",
        "responsibilities": [
          "通过 TaskRunner 编排多阶段修复管道：扫描清理、AST提取、修复和验证。",
          "管理修复重试逻辑，配置最大尝试次数（MAX_FIX_RETRIES = 2），并通过任务状态重置实现重新检查。",
          "集成运行时会话和检查点系统（executionCheckpoint.startRun），以跟踪和恢复执行状态。",
          "通过 createTaskContext 准备任务上下文，并使用 resetTaskState 重置重新检查的任务状态。",
          "在清单中记录修复操作的使用指标。",
          "解析 LLM 设置和执行配置文件（GlobalLLMConfig、resolveLLMSettings、resolveExecutionProfileFromSettings）。",
          "通过 toArchSpineError 将错误转换为 ArchSpineError，以实现一致的错误报告。"
        ],
        "outOfScope": [
          "各个任务的实际实现（FixTask、ScanAndCleanupTask、ASTExtractionTask、ValidationTask）。",
          "底层 LLM 客户端处理和密钥管理。",
          "文件系统扫描策略定义。",
          "配置加载和应用程序初始化。"
        ]
      }
    }
