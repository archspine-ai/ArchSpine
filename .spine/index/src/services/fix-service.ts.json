  "semantic": {
    "role": "Service-layer orchestrator for the ArchSpine architectural fix pipeline, managing the sequential execution of scanning, AST extraction, LLM-driven correction, and validation tasks, with retry support and runtime session integration.",
    "responsibilities": [
      "Orchestrates the multi-stage fix pipeline: scan-and-cleanup, AST extraction, fix, and validation using TaskRunner.",
      "Manages fix retry logic with a configurable maximum attempts (MAX_FIX_RETRIES = 2) and recheck passes via task state reset.",
      "Integrates with the runtime session and checkpoint system (executionCheckpoint.startRun) to track and resume execution state.",
      "Prepares task context via createTaskContext and resets task state for recheck using resetTaskState.",
      "Records usage metrics of the fix operation within the manifest.",
      "Resolves LLM settings and execution profile (GlobalLLMConfig, resolveLLMSettings, resolveExecutionProfileFromSettings).",
      "Handles error conversion to ArchSpineError with toArchSpineError for consistent error reporting."
    ],
    "outOfScope": [
      "Actual implementation of individual tasks (FixTask, ScanAndCleanupTask, ASTExtractionTask, ValidationTask).",
      "Low-level LLM client handling and secret management.",
      "File system scan policy definitions.",
      "Configuration loading and application initialization."
    ],
    "invariants": [
      "Must execute a fix pipeline at most MAX_FIX_RETRIES times before aborting.",
      "Must use runtime session and checkpointing for durable execution tracking.",
      "Should reside under src/services/ and not in src/infra/ (satisfied)."
    ],
    "changeIntent": {
      "architecturalIntent": "Improve robustness of the fix service by enhancing checkpoint handling, retry logic, and cross-platform compatibility.",
      "recentChangeIntent": "Resolve TTY hang during fix execution, checkpoint retry crash, --yes flag propagation, and Windows compatibility issues."
    },
    "publicSurface": [
      "runFix",
      "FixService",
      "FixRunSummary",
      "FixServiceOptions"
    ],
