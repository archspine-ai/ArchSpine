  "semantic": {
    "role": "Pre-publish validation and safety service for the ArchSpine publish pipeline.",
    "responsibilities": [
      "Ensure the `.spine` directory exists in the target root directory before publishing.",
      "Validate that the snapshot index is present and not locked (i.e., no active compressed snapshot being written).",
      "Warn when the current artifact strategy is set to 'local' to avoid unintentional publishing of local-only artifacts."
    ],
    "outOfScope": [
      "Does not perform the actual publish or upload of artifacts.",
      "Does not handle runtime IO errors or logging infrastructure.",
      "Does not manage or modify the lock file itself beyond reading it."
    ],
    "invariants": [
      "The `.spine` directory must exist for a valid ArchSpine project.",
      "A locked snapshot index (detected via lock file) blocks publishing.",
      "Local artifact strategy should trigger a user-facing warning during publish preparation."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide deterministic pre-flight checks that must pass before publish can proceed, enforcing project structure and lock semantics.",
      "recentChangeIntent": "Initial commit establishing publish validation logic."
    },
    "publicSurface": [
      {
        "symbolName": "assertPublishRuntimeBaseline",
        "kind": "Function",
        "description": "Validates that the `.spine` directory exists at the given root. Throws ArchSpineError with code `PublishRuntimeMissing` if missing."
