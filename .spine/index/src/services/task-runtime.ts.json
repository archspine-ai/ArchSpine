  "semantic": {
    "role": "Service orchestrator that initializes and configures the complete task execution context, gluing together scanner, aggregator, AST extractor, rule engine, output manager, context engine, and lock manager based on provided options.",
    "responsibilities": [
      "Parse relevance diagnostics mode from the SPINE_DIAGNOSTICS_MODE environment variable.",
      "Open the project manifest and create task state and task artifacts state.",
      "Instantiate and configure Scanner, Aggregator, ASTExtractor, RuleEngine, OutputManager, ContextEngine, and LockManager.",
      "Combine all initialized components into a single PreparedTaskContext object for downstream use.",
      "Expose the ServiceOptions interface to define required inputs (rootDir, llmClient, scanPolicy)."
    ],
    "outOfScope": [
      "Direct file system scanning – delegated to Scanner.",
      "AST extraction from source files – delegated to ASTExtractor.",
      "Rule evaluation – delegated to RuleEngine.",
      "Output formatting/export – delegated to OutputManager.",
      "Context enrichment or LLM interaction – delegated to ContextEngine.",
      "Concurrency control – delegated to LockManager.",
      "Manifest persistence – delegated to Manifest.open/close."
    ],
    "invariants": [
      "The rootDir option must be a valid directory path.",
      "The llmClient option must be provided if the context engine requires it.",
      "The scanPolicy option must be provided to define scanning behavior.",
      "The manifest must be openable and closeable."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a single entry point for initializing all runtime components needed to execute a spine task, decoupling configuration from execution.",
      "recentChangeIntent": "Initial commit – establishes the baseline orchestration service for task context creation."
    },
    "publicSurface": [
      {
        "symbolName": "createTaskContext",
        "description": "Factory function that accepts TaskContextOptions and returns a PreparedTaskContext. It initializes all engines and infra components, parses environment-based diagnostics mode, and wires everything together. This is the primary way to bootstrap a task execution."
      },
      {
        "symbolName": "ServiceOptions",
        "description": "Interface defining the configuration shape required to create a task context: rootDir, llmClient, scanPolicy, and other optional settings. Consumers must pass an object conforming to this interface."
      },
      {
        "symbolName": "PreparedTaskContext",
        "description": "Interface representing the fully initialized runtime context, exposing references to Scanner, Aggregator, ASTExtractor, RuleEngine, OutputManager, ContextEngine, LockManager, task state, etc. Consumed by the task execution pipeline."
      }
    ],
