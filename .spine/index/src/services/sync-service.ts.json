  "semantic": {
    "role": "Service orchestrator coordinating the multi-stage synchronization pipeline for the ArchSpine mirror system.",
    "responsibilities": [
      "Orchestrates the full sync workflow: file scanning, AST extraction, summarization, state commit, reconciliation, and post-commit derivation.",
      "Manages protected output detection and warnings via spine-gate integration before committing changes.",
      "Coordinates checkpointing and resume logic through ExecutionCheckpointStore to allow recovery from partial failures.",
      "Manages language discovery and registry updates to ensure the sync operates on correct file types.",
      "Evaluates repair policy decisions when the sync encounters drift or corruption.",
      "Performs file hashing via Manifest to detect stale summaries needing regeneration.",
      "Wraps the entire workflow inside a runtime session (runWithRuntimeSession) for transactional boundaries and error scoping."
    ],
    "outOfScope": [
      "Implementation details of individual task algorithms (e.g., AST parsing, summarization, reconciliation).",
      "Low-level filesystem I/O beyond orchestration (delegated to runtimeIO).",
      "UI/CLI rendering logic (delegated to external UI modules).",
      "Language registration and extension tracking (handled by LangRegistry).",
      "Protected output baseline writing and mutation detection (handled by infra/spine-gate)."
    ],
    "invariants": [
      "The sync workflow must be idempotent – re-running from scratch or resume produces consistent state.",
      "All protected output mutations must be detected and confirmed by the user before being written.",
      "Checkpointing must allow resume from the point of failure without redoing completed stages.",
      "Language registry must be synchronized with the latest discovered languages before task execution."
    ],
    "changeIntent": {
      "architecturalIntent": "Provide a centralized orchestrator that decouples the sync pipeline stages from each other and from the runtime environment, enabling composability and resilience.",
      "recentChangeIntent": "No direct evidence in the source that this file was modified in the referenced commit; the commit focused on ESLint fixes, prompt injection, and better-sqlite3 compatibility."
    },
    "publicSurface": [
      {
        "symbolName": "SyncService",
        "kind": "Class",
        "description": "Primary orchestrator class that executes the entire ArchSpine sync workflow. Consumed by CLI commands and the MCP server to trigger a sync operation."
      },
      {
        "symbolName": "SyncStats",
        "kind": "Interface",
        "description": "Data structure returned after a sync execution, summarizing counts of scanned, extracted, summarized, committed, and reconciled files."
      },
      {
        "symbolName": "SyncExecutionOptions",
        "kind": "Interface",
        "description": "Configuration options that control how a single sync run behaves, including resume mode, repair policy, and protected output handling."
      },
      {
        "symbolName": "SyncWorkflowOptions",
        "kind": "Interface",
        "description": "Configuration options that determine which stages of the sync pipeline are executed (e.g., skip summarize, skip reconcile)."
      }
    ],
