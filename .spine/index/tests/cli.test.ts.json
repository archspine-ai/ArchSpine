  "semantic": {
    "role": "Vitest end-to-end integration test suite for ArchSpine's CLI command workflow and core engine orchestration, validating real command-line behavior with a custom mock LLM client.",
    "responsibilities": [
      "Sets up isolated temporary directories for each test case to avoid side effects.",
      "Defines a custom E2EMockClient class implementing LLMClient interface to simulate both successful and failing LLM responses for robustness testing.",
      "Executes ArchSpine CLI commands (e.g., archspine sync) via child_process.execSync to validate real command-line behavior.",
      "Invokes core engines (runCheck, runFix, runUsageReport) and the sync workflow (runSyncWorkflow) to verify orchestration and error handling.",
      "Cleans up temporary test directories after each test using afterEach and fs.rmSync."
    ],
    "outOfScope": [
      "Unit tests for individual modules or functions.",
      "Tests against a real LLM provider endpoint.",
      "Production code or deployment configuration."
    ],
    "invariants": [
      "Test files must end with .test.ts or .spec.ts (rule test-file-suffix is satisfied).",
      "Each test must set up its own isolated temporary directory to prevent cross-test pollution.",
      "LLM interactions must be simulated via a mock client, never using a real provider."
    ],
    "changeIntent": {
      "architecturalIntent": "Validate the end-to-end CLI workflow and core engine orchestration of ArchSpine's architectural governance and semantic layer in a controlled, reproducible environment.",
      "recentChangeIntent": "ArchSpine v1.0.0 introduced a complete architectural governance and semantic layer; this test suite ensures that the CLI sync, check, fix, and usage commands function correctly together, paving the way for reliable AI-driven repository management."
    },
