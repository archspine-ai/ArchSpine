{
  "schemaVersion": "1.0.0",
  "project": {
    "name": "archspine",
    "locales": ["English", "Simplified Chinese"]
  },
  "llm": {},
  "mcp": {
    "contextMode": "off"
  },
  "hooks": {
    "preCommit": false,
    "syncMode": "hook"
  },
  "artifacts": {
    "strategy": "distributable",
    "experimentalViewLayer": true,
    "enabledViews": ["public-surface", "risk-hotspots", "architecture-diagram"]
  },
  "scanPolicy": {
    "fileSource": "git-tracked",
    "ignoreChain": {
      "inheritGitIgnore": true,
      "projectIgnore": ".spineignore",
      "localIgnore": ".spineignore.local"
    },
    "protocolExclusions": [".spine/"],
    "protocolInclusions": [".spine/rules/", ".spine/config.json"]
  },
  "initState": {
    "artifactStrategy": "distributable",
    "agentInstructionsFile": "AGENTS.md",
    "agentInstructionsCreatedByArchSpine": false,
    "spineIgnoreManaged": true,
    "spineIgnoreCreatedByArchSpine": false,
    "searchIgnoreManaged": true,
    "searchIgnoreCreatedByArchSpine": false,
    "gitIgnoreManaged": true,
    "gitIgnoreCreatedByArchSpine": false,
    "gitAttributesManaged": true,
    "gitAttributesCreatedByArchSpine": false
  }
}
